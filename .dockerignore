# ── Git ───────────────────────────────────────────────────────────────────────
.git/
.gitignore

# ── Environment (never bake secrets into image) ───────────────────────────────
.env
.env.*
!.env.example

# ── Node modules (rebuilt inside Docker) ─────────────────────────────────────
node_modules/
frontend-react/node_modules/

# ── Frontend build artifacts (rebuilt in Docker Stage 1) ─────────────────────
frontend-react/dist/
frontend-react/.vite/

# ── Logs (mounted as volume at runtime) ──────────────────────────────────────
logs/

# ── Dev / test / docs ─────────────────────────────────────────────────────────
tests/
docs/
*.test.js
*.spec.js

# ── OS / IDE files ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ── PM2 (not used inside Docker) ─────────────────────────────────────────────
ecosystem.config.js

# ── Misc ──────────────────────────────────────────────────────────────────────
README.md
*.md
