# ─────────────────────────────────────────────────────────────────────────────
# AMA Timbangan Aditif — Environment Variables
# Copy this file to .env and fill in the values before running.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Serial / RS-232 ───────────────────────────────────────────────────────────
# Docker on Windows (WSL2 backend): COM ports cannot be passed directly to
# Linux containers.  Use a serial-over-TCP bridge (e.g. socat + com0com) or
# switch to Windows Containers.  On a Linux host use /dev/ttyUSB0, /dev/ttyS0, etc.
SERIAL_SMALL_PORT=/dev/ttyS0
SERIAL_SMALL_BAUD_RATE=9600
SERIAL_LARGE_PORT=/dev/ttyS1
SERIAL_LARGE_BAUD_RATE=9600

# ── Load cell ─────────────────────────────────────────────────────────────────
MAX_WEIGHT=100
OVERLOAD_THRESHOLD=90
ALERT_ENABLED=true

# ── Database (MySQL / MariaDB) ────────────────────────────────────────────────
DB_HOST=mysql
DB_USER=amauser
DB_PASSWORD=change_me_strong_password
DB_NAME=amanerve_loadcell
DB_CONNECTION_LIMIT=10

# MySQL root password (used by the mysql service in docker-compose only)
MYSQL_ROOT_PASSWORD=change_me_root_password

# ── External API ──────────────────────────────────────────────────────────────
KANBAN_API_URL=https://services.ama.id/kanban

# ── Frontend (set automatically by Dockerfile — override only if needed) ──────
# FRONTEND_DIR=/app/public
